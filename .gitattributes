# Set the default behavior, in case users don't have core.autocrlf set.
* text=auto

# Explicitly declare text files we want normalized
*.{bat,cmd,sh,txt,py,html,css,js,json,xml,md,cfg,ini,yaml,yml,c,h,cpp,hpp,java,cs,rb,php,erb,epp} text

# Declare files that should always use native line endings
*.{png,jpg,gif,jpeg,svg,ico,eot,woff,woff2,ttf,otf,dat,bin,exe,dll,obj,lib,so,dylib,pdf,gz,zip,tar,7z,rar,mp3,mp4,avi,mov,wmv,mkv,flv,ogg,webm,m4a} binary
